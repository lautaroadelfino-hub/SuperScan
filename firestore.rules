rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar autenticación
    function isAuth() {
      return request.auth != null;
    }

    // Colección: productos
    match /productos/{document=**} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Colección: productos_usuarios
    match /productos_usuarios/{document=**} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Colección: usuarios
    match /usuarios/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // Colección: tickets
    match /tickets/{ticketId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Colección: observaciones_precios
    match /observaciones_precios/{obsId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Colección: listas compartidas (en código figura como shared_lists)
    match /shared_lists/{listId} {
      allow read, update, delete: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth() && request.auth.uid in request.resource.data.members;
      
      // Subcolección de ítems de la lista
      match /items/{itemId} {
        allow read, write: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/shared_lists/$(listId)).data.members;
      }
    }
  }
}
